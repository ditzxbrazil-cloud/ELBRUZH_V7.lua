-- tab switch bottom
local curBTab="http"
function switchBTab(id)
	curBTab=id
	HttpPanel.Visible=(id=="http"); MemPanel.Visible=(id=="mem"); SpyPanel.Visible=(id=="spy"); VulnPanel.Visible=(id=="vuln")
	local tabs={http=BTabHTTP,mem=BTabMem,spy=BTabSpy,vuln=BTabVuln}
	for tid,btn in pairs(tabs) do btn.TextColor3=tid==id and Color3.fromRGB(100,220,120) or Color3.fromRGB(80,80,80); btn.BackgroundColor3=tid==id and Color3.fromRGB(20,28,20) or Color3.fromRGB(14,14,14) end
end
BTabHTTP.Activated:Connect(function() switchBTab("http") end)
BTabMem.Activated:Connect(function()  switchBTab("mem")  end)
BTabSpy.Activated:Connect(function()  switchBTab("spy")  end)
BTabVuln.Activated:Connect(function() switchBTab("vuln") end)
switchBTab("http")

