local LINE_H = 18

local KEYWORDS = {
	["local"]=1,["function"]=1,["end"]=1,["if"]=1,["then"]=1,
	["else"]=1,["elseif"]=1,["for"]=1,["in"]=1,["do"]=1,
	["while"]=1,["repeat"]=1,["until"]=1,["return"]=1,
	["true"]=1,["false"]=1,["nil"]=1,["not"]=1,["and"]=1,["or"]=1,
}

local function lineColor(line)
	if line:match("^%s*%-%-") then return Color3.fromRGB(90,120,90) end
	if line:match('"') or line:match("'") then return Color3.fromRGB(220,170,90) end
	local first = line:match("^%s*(%a+)")
	if first and KEYWORDS[first] then return Color3.fromRGB(180,100,255) end
	if line:match(":[%a_]") then return Color3.fromRGB(100,200,220) end
	return Color3.fromRGB(200,225,200)
end

local RENDER_MAX = 99999

local function renderSource(source)
	for _, v in pairs(CodeScroll:GetChildren()) do if v:IsA("Frame") or v:IsA("TextLabel") then v:Destroy() end end
	for _, v in pairs(LineScroll:GetChildren()) do if v:IsA("TextLabel") then v:Destroy() end end

	local lines = source:split("\n")
	local totalLines = #lines
	local showLines = math.min(totalLines, RENDER_MAX)
	local totalH = totalLines * LINE_H

	for i = 1, showLines do
		local line = lines[i]
		local nl = Instance.new("TextLabel", LineScroll)
		nl.Size = UDim2.new(1,0,0,LINE_H); nl.LayoutOrder = i
		nl.BackgroundTransparency = 1; nl.Text = tostring(i)
		nl.Font = Enum.Font.Code; nl.TextSize = 13
		nl.TextColor3 = Color3.fromRGB(55,75,55)
		nl.TextXAlignment = Enum.TextXAlignment.Right
		do local p=Instance.new("UIPadding",nl); p.PaddingRight=UDim.new(0,4) end

		local cl = Instance.new("TextLabel", CodeScroll)
		cl.Size = UDim2.new(0,900,0,LINE_H); cl.LayoutOrder = i
		cl.BackgroundColor3 = i%2==0 and Color3.fromRGB(20,20,20) or Color3.fromRGB(16,16,16)
		cl.BorderSizePixel = 0; cl.Text = line
		cl.Font = Enum.Font.Code; cl.TextSize = 13
		cl.TextColor3 = lineColor(line)
		cl.TextXAlignment = Enum.TextXAlignment.Left
		cl.TextTruncate = Enum.TextTruncate.AtEnd
		do local p=Instance.new("UIPadding",cl); p.PaddingLeft=UDim.new(0,4) end
	end

	if totalLines > RENDER_MAX then
		totalH = (RENDER_MAX + 2) * LINE_H
	end

	LineScroll.CanvasSize  = UDim2.new(0,0,0,totalH)
	CodeScroll.CanvasSize  = UDim2.new(0,900,0,totalH)
	CodeScroll.CanvasPosition = Vector2.new(0,0)
end

