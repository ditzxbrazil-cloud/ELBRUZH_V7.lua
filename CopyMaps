local currentTab = "source"
local scannedAssets = {}
local scannedSeenIds = {}

local function accumulateAssets(newAssets)
	local added = 0
	for _, a in ipairs(newAssets) do
		if not scannedSeenIds[a.id] then
			scannedSeenIds[a.id] = true
			table.insert(scannedAssets, a)
			added = added + 1
		end
	end
	return added
end

local function clearAllAssets()
	scannedAssets = {}
	scannedSeenIds = {}
end

local ASSET_TYPE_COLORS = {
	Sound   = Color3.fromRGB(100, 180, 255),
	Image   = Color3.fromRGB(255, 200, 80),
	Mesh    = Color3.fromRGB(180, 130, 255),
	Decal   = Color3.fromRGB(255, 150, 100),
	Hat     = Color3.fromRGB(100, 220, 150),
	Bundle  = Color3.fromRGB(220, 100, 150),
	Unknown = Color3.fromRGB(120, 120, 120),
}

local function guessAssetType(context)
	context = context:lower()
	if context:find("sound") or context:find("music") or context:find("sfx") or context:find("audio") then return "Sound"
	elseif context:find("mesh") then return "Mesh"
	elseif context:find("decal") then return "Decal"
	elseif context:find("hat") or context:find("bundle") or context:find("ugc") then return "Hat"
	elseif context:find("image") or context:find("icon") or context:find("texture") or context:find("img") or context:find("thumbnail") then return "Image"
	end
	return "Unknown"
end

local function scanAssets(source, sourceName)
	local found = {}
	local seen = {}
	local function addId(id, typeName)
		if not seen[id] then
			seen[id] = true
			table.insert(found, {id = id, assetType = typeName or "Unknown", sourceName = sourceName or "?"})
		end
	end
	for lineStr in (source .. "\n"):gmatch("([^\n]*)\n") do
		local lowLine = lineStr:lower()
		for id in lineStr:gmatch("rbxassetid://(%d+)") do addId(id, guessAssetType(lowLine)) end
		for id in lineStr:gmatch('"(%d%d%d%d%d%d%d%d%d%d+)"') do addId(id, guessAssetType(lowLine)) end
	end
	return found
end

local ASSET_PROPS = {
	{prop="SoundId",    type="Sound"},
	{prop="MeshId",     type="Mesh"},
	{prop="TextureID",  type="Mesh"},
	{prop="Texture",    type="Image"},
	{prop="Image",      type="Image"},
	{prop="BackgroundImage", type="Image"},
	{prop="ImageId",    type="Image"},
	{prop="VideoId",    type="Video"},
	{prop="AnimationId",type="Anim"},
}
local function scanObjectProps(obj, sourceName)
	local found = {}
	local seen = {}
	for _, entry in ipairs(ASSET_PROPS) do
		local ok, val = pcall(function() return obj[entry.prop] end)
		if ok and type(val) == "string" then
			local id = val:match("rbxassetid://(%d+)") or val:match("^(%d%d%d%d%d%d%d%d%d+)$")
			if id and not seen[id] then
				seen[id] = true
				table.insert(found, {id=id, assetType=entry.type, sourceName=sourceName or obj.Name})
			end
		end
	end
	return found
end

