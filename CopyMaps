	table.sort(res,function(a,b) local o={CRITICAL=1,WARNING=2,INFO=3}; if a.sev~=b.sev then return (o[a.sev] or 9)<(o[b.sev] or 9) end; return a.line<b.line end)
	for i,r in ipairs(res) do
