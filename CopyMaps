local function runVuln()
	for _,v in pairs(VulnScroll:GetChildren()) do if v:IsA("Frame") or v:IsA("TextLabel") then v:Destroy() end end
	if currentSource=="" then VulnInfoLbl.Text="Pilih script dulu!"; return end
	local res={}; local ls=currentSource:split("\n")
	for i,line in ipairs(ls) do
		for _,p in ipairs(VPAT) do if line:match(p.pat) then table.insert(res,{sev=p.sev,line=i,msg=p.msg,code=line}) end end
		if line:match("['\"]sk%-") then table.insert(res,{sev="CRITICAL",line=i,msg="API key hardcoded",code=line}) end
		if line:match("https?://") and not line:match("roblox%.com") then table.insert(res,{sev="WARNING",line=i,msg="External URL",code=line}) end
	end
	local cC,wC,iC=0,0,0; for _,r in ipairs(res) do if r.sev=="CRITICAL" then cC=cC+1 elseif r.sev=="WARNING" then wC=wC+1 else iC=iC+1 end end
