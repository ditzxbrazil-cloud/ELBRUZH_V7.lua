local function removeChildren(obj)
	local data = rowMap[obj]
	if not data or not data.childrenInserted then return end
	data.childrenInserted = false
	local children = {}
	for _, child in ipairs(obj:GetChildren()) do
		if rowMap[child] then table.insert(children, child) end
	end
	for _, child in ipairs(children) do
		removeChildren(child)
		local d = rowMap[child]
		if d and d.row and d.row.Parent then d.row:Destroy() end
		rowMap[child] = nil
		expanded[child] = nil
	end
end

local insertChildren

local function rowBgColor(depth)
	if depth == 0 then return Color3.fromRGB(10,10,10) end
	if depth == 1 then return Color3.fromRGB(32,32,32) end
	local base = 36 + math.min(depth - 2, 4) * 5
	return Color3.fromRGB(base, base, base)
end

local function rowHoverColor(depth)
	if depth == 0 then return Color3.fromRGB(20,45,20) end
	local base = 45 + math.min(depth - 1, 4) * 4
	return Color3.fromRGB(base, math.min(base+18,70), base)
end

local function makeRow(obj, depth, path)
	local hasKids = #obj:GetChildren() > 0
	local script_ = isScript(obj)
	local indent  = depth * 14
	local bgColor = rowBgColor(depth)

	local row = Instance.new("TextButton", ExpScroll)
	row.Size = UDim2.new(1,0,0,ROW_H)
	row.LayoutOrder = 0
	row.BackgroundColor3 = bgColor
	row.BorderSizePixel = 0; row.Text = ""; row.AutoButtonColor = false
	row.Name = obj.Name

	local arrow = Instance.new("TextLabel", row)
	arrow.Size = UDim2.new(0,12,1,0); arrow.Position = UDim2.new(0,indent+2,0,0)
	arrow.BackgroundTransparency = 1
	arrow.Text = hasKids and "▶" or ""
	arrow.Font = Enum.Font.Gotham; arrow.TextSize = 11
	arrow.TextColor3 = Color3.fromRGB(90,90,90)

	local iconLbl = Instance.new("TextLabel", row)
	iconLbl.Size = UDim2.new(0,24,1,0); iconLbl.Position = UDim2.new(0,indent+16,0,0)
	iconLbl.BackgroundTransparency = 1; iconLbl.Text = getIcon(obj)
	iconLbl.Font = Enum.Font.Code; iconLbl.TextSize = 11
	iconLbl.TextColor3 = getIconColor(obj)

	local nameLbl = Instance.new("TextLabel", row)
	nameLbl.Size = UDim2.new(1,-(indent+44),1,0); nameLbl.Position = UDim2.new(0,indent+42,0,0)
	nameLbl.BackgroundTransparency = 1; nameLbl.Text = obj.Name
	nameLbl.Font = script_ and Enum.Font.GothamBold or Enum.Font.Gotham
	nameLbl.TextSize = 14
	nameLbl.TextColor3 = script_ and Color3.fromRGB(230,210,80) or Color3.fromRGB(205,205,205)
	nameLbl.TextXAlignment = Enum.TextXAlignment.Left
	nameLbl.TextTruncate = Enum.TextTruncate.AtEnd

	rowMap[obj] = {row=row, arrow=arrow, childrenInserted=false, order=0, path=path, depth=depth, bgColor=bgColor}

	row.MouseEnter:Connect(function()
		if selectedRow == row then return end
		if selectedItems[obj] then tw(row,{BackgroundColor3=MULTI_HOVER_COLOR})
		else tw(row,{BackgroundColor3=rowHoverColor(depth)}) end
	end)
	row.MouseLeave:Connect(function()
		if selectedRow == row then return end
		if selectedItems[obj] then tw(row,{BackgroundColor3=MULTI_SELECT_COLOR})
		else tw(row,{BackgroundColor3=bgColor}) end
	end)

	row.Activated:Connect(function()
		if isSearchMode then return end

		if multiMode then
			if selectedItems[obj] then
				selectedItems[obj] = nil
				selectedCount = selectedCount - 1
				tw(row,{BackgroundColor3=bgColor})
			else
				selectedItems[obj] = row
				selectedCount = selectedCount + 1
				tw(row,{BackgroundColor3=MULTI_SELECT_COLOR})
			end
			updateMultiLabel()
			selectedObj = obj
			selectSource(obj)
			return
		end

		deselectAll()
		selectedRow = row; selectedObj = obj
		tw(row,{BackgroundColor3=Color3.fromRGB(28,70,35)})
		selectSource(obj)

		if hasKids then
			local freshData = rowMap[obj]
			if expanded[obj] then
				expanded[obj] = false
				arrow.Text = "▶"
				removeChildren(obj)
			else
				expanded[obj] = true
				arrow.Text = "▼"
				if freshData and not freshData.childrenInserted then
					freshData.childrenInserted = true
					insertChildren(obj, depth+1, freshData.path)
				end
			end
		end
	end)

	return row
end

insertChildren = function(parent, depth, parentPath)
	local children = parent:GetChildren()
	for i, child in ipairs(children) do
		local childPath = {}
		for _, v in ipairs(parentPath) do table.insert(childPath, v) end
		table.insert(childPath, i)
		makeRow(child, depth, childPath)
	end
	resortRows()
end

