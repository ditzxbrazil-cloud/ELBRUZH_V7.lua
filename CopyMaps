-- ============================================================
-- // SOURCE READER
-- ============================================================
local function getSourceOf(obj)
	if not (obj:IsA("LocalScript") or obj:IsA("Script") or obj:IsA("ModuleScript")) then
		return nil, "bukan script"
	end
	local src = nil
	local ok1, s1 = pcall(function() return obj.Source end)
	if ok1 and s1 and s1 ~= "" then src = s1 end

	if not src then
		local ok2, s2 = pcall(function()
			if decompile then return decompile(obj) end
			return nil
		end)
		if ok2 and s2 and s2 ~= "" then src = s2 end
	end

	if not src then
		local ok3, s3 = pcall(function()
			if getscriptbytecode then return getscriptbytecode(obj) end
			return nil
		end)
		if ok3 and s3 and s3 ~= "" then
			src = "-- [BYTECODE:" .. tostring(#s3) .. " bytes] " .. obj.Name
		end
	end

	if not src then
		src = "-- " .. obj.ClassName .. ": " .. obj.Name .. " (tidak bisa dibaca)"
	end
	return src
end

-- Rekursif kumpulin semua script dari obj dan semua descendants
local function collectAllScripts(obj, results, maxDepth, currentDepth)
	currentDepth = currentDepth or 0
	maxDepth = maxDepth or 10
	if currentDepth > maxDepth then return end

	if obj:IsA("LocalScript") or obj:IsA("Script") or obj:IsA("ModuleScript") then
		local src = getSourceOf(obj)
		if src then
			table.insert(results, {
				name = obj.Name,
				path = obj:GetFullName(),
				class = obj.ClassName,
				source = src
			})
		end
	end

	for _, child in ipairs(obj:GetChildren()) do
		collectAllScripts(child, results, maxDepth, currentDepth + 1)
	end
end

local function selectSource(obj)
	PlaceLbl.Visible = false
	local src = ""
	if obj:IsA("LocalScript") or obj:IsA("Script") or obj:IsA("ModuleScript") then
		src = getSourceOf(obj)
		currentSource = src
		renderSource(src)
	else
		local lines = {
			"-- " .. obj.ClassName .. ": " .. obj.Name,
			"-- Path: " .. obj:GetFullName(),
			"-- Children: " .. #obj:GetChildren(),
			""
		}
		for _, child in ipairs(obj:GetChildren()) do
			table.insert(lines, "--   " .. child.Name .. "  [" .. child.ClassName .. "]")
		end
		currentSource = table.concat(lines, "\n")
		src = currentSource
		renderSource(currentSource)
	end
	task.defer(function()
		local assets = scanAssets(src, obj.Name)
		local propAssets = scanObjectProps(obj, obj.Name)
		for _, a in ipairs(propAssets) do table.insert(assets, a) end
		local added = accumulateAssets(assets)
		if added > 0 then renderAssets() end
	end)
end

