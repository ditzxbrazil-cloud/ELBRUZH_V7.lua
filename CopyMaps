local function highlightResult(rowFrame, isActive)
	if isActive then tw(rowFrame, {BackgroundColor3 = Color3.fromRGB(50,120,50)})
	else tw(rowFrame, {BackgroundColor3 = Color3.fromRGB(35,65,35)}) end
end

local function clearSearchHighlight()
	for _, data in pairs(rowMap) do
		if data.row and data.row.Parent then
			tw(data.row, {BackgroundColor3 = data.bgColor or rowBgColor(data.depth or 0)})
			data.row.Visible = true
		end
	end
end

local function jumpToResult(idx)
	if #searchResults == 0 then return end
	searchIdx = ((idx - 1) % #searchResults) + 1
	for i, entry in ipairs(searchResults) do
		if entry.row and entry.row.Parent then highlightResult(entry.row, i == searchIdx) end
	end
	local activeRow = searchResults[searchIdx] and searchResults[searchIdx].row
	if activeRow then
		selectedRow = activeRow
		selectedObj = searchResults[searchIdx].obj
		selectSource(selectedObj)
		local rowPos = activeRow.AbsolutePosition.Y - ExpScroll.AbsolutePosition.Y + ExpScroll.CanvasPosition.Y
		ExpScroll.CanvasPosition = Vector2.new(0, math.max(0, rowPos - ROW_H * 3))
	end
	SearchCount.Text = searchIdx .. "/" .. #searchResults
end

local function deepSearch(query)
	searchResults = {}
	searchIdx = 0
	query = query:lower()
	for obj, data in pairs(rowMap) do
		if data.row and data.row.Parent then
			local match = obj.Name:lower():find(query, 1, true) or obj.ClassName:lower():find(query, 1, true)
			if match then table.insert(searchResults, {obj=obj, row=data.row}) end
		end
	end
	return #searchResults
end

