local function pathLess(a, b)
	for i = 1, math.max(#a, #b) do
		local ai = a[i] or 0
		local bi = b[i] or 0
		if ai ~= bi then return ai < bi end
	end
	return false
end

local function resortRows()
	local list = {}
	for _, data in pairs(rowMap) do
		if data.row and data.row.Parent then table.insert(list, data) end
	end
	table.sort(list, function(a, b) return pathLess(a.path, b.path) end)
	for i, data in ipairs(list) do data.row.LayoutOrder = i end
end

