local VCOL={CRITICAL=Color3.fromRGB(200,70,70),WARNING=Color3.fromRGB(210,195,55),INFO=Color3.fromRGB(30,180,70)}
local VPAT={
	{sev="CRITICAL",pat="loadstring%s*%(",msg="loadstring — RCE"},
	{sev="WARNING", pat="DataStore.-:SetAsync",msg="SetAsync tanpa validasi"},
	{sev="WARNING", pat="OnServerEvent.-:Connect",msg="Remote handler"},
	{sev="INFO",    pat="while%s+true%s+do",msg="Infinite loop"},
