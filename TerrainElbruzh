-- Fungsi cek ke GitHub (Anti-Error gsub)
local function verify(input)
    if not input or input == "" then return false end
    
    local success, result = pcall(function() 
        return game:HttpGet(KEY_URL .. "?t=" .. tick()) 
    end)
    
    if success and result then
        local cleanInput = input:gsub("%s+", "")
        local myID = tostring(lp.UserId)
        
        for line in result:gmatch("[^\r\n]+") do
            local cleanLine = line:gsub("%s+", "")
            -- Syarat: Kode di GitHub harus sama dengan input DAN ada UserID pembeli di dalamnya
            if cleanInput == cleanLine and cleanInput:find(myID) then
                return true
            end
        end
    end
    return false
end

