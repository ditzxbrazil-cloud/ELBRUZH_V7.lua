    end
    code = code .. "}\n"
    code = code .. "local leafyGrassColors = {"
    for i, c in ipairs(leafyGrassColors) do
        code = code .. (i > 1 and "," or "") .. "Color3.fromRGB(" .. math.floor(c.color.R*255) .. "," .. math.floor(c.color.G*255) .. "," .. math.floor(c.color.B*255) .. ")"
    end
    code = code .. "}\n"
    code = code .. "local groundColors = {"
    for i, c in ipairs(groundColors) do
        code = code .. (i > 1 and "," or "") .. "Color3.fromRGB(" .. math.floor(c.color.R*255) .. "," .. math.floor(c.color.G*255) .. "," .. math.floor(c.color.B*255) .. ")"
    end
    code = code .. "}\n\n"
    
    code = code .. "local function BL(d)\n"
    code = code .. "    local pos = Vector3.new(d[1], d[2], d[3])\n"
    code = code .. "    local mats = {Grass=Enum.Material.Grass,LeafyGrass=Enum.Material.LeafyGrass,Rock=Enum.Material.Rock,Sand=Enum.Material.Sand,Water=Enum.Material.Water,Snow=Enum.Material.Snow,Mud=Enum.Material.Mud,Ground=Enum.Material.Ground,Asphalt=Enum.Material.Asphalt,Brick=Enum.Material.Brick,Wood=Enum.Material.WoodPlanks,Concrete=Enum.Material.Concrete,Ice=Enum.Material.Ice}\n"
    code = code .. "    local mat = mats[d[7]] or Enum.Material.Grass\n"
    code = code .. "    pcall(function() Terrain:SetMaterialColor(Enum.Material.Grass, grassColors[d[9] or 3]) end)\n"
    code = code .. "    pcall(function() Terrain:SetMaterialColor(Enum.Material.LeafyGrass, leafyGrassColors[d[10] or 3]) end)\n"
    code = code .. "    pcall(function() Terrain:SetMaterialColor(Enum.Material.Ground, groundColors[d[11] or 2]) end)\n"
    code = code .. "    if d[8] == 'Block' then\n"
    code = code .. "        Terrain:FillBlock(CFrame.new(pos), Vector3.new(d[4], d[5], d[6]), mat)\n"
    code = code .. "    else\n"
    code = code .. "        Terrain:FillBall(pos, math.max(d[4], d[5], d[6])/2, mat)\n"
    code = code .. "    end\n"
    code = code .. "end\n\n"
    
    local batchSize = 20
    local numBatches = math.ceil(#SpawnedData / batchSize)
    for b = 1, numBatches do
        code = code .. "for _,d in ipairs({"
        local startIdx = (b-1) * batchSize + 1
        local endIdx = math.min(b * batchSize, #SpawnedData)
        for i = startIdx, endIdx do
            local d = SpawnedData[i]
            code = code .. "{" .. d[1] .. "," .. d[2] .. "," .. d[3] .. "," .. d[4] .. "," .. d[5] .. "," .. d[6] .. ",'" .. d[7] .. "','" .. (d[8] or "Ball") .. "'," .. (d[9] or 3) .. "," .. (d[10] or 3) .. "," .. (d[11] or 2) .. "}"
            if i < endIdx then code = code .. "," end
        end
        code = code .. "})do BL(d)end\n"
    end
    code = code .. "\nprint('[Terrain] " .. #SpawnedData .. " blocks spawned!')"
    return code
end

