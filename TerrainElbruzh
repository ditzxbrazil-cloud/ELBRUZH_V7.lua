--// Raycast
local function GetRaycast()
    local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    local ray = Camera:ViewportPointToRay(center.X, center.Y)
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Blacklist
    if PreviewPart then params.FilterDescendantsInstances = {PreviewPart} end
    return Workspace:Raycast(ray.Origin, ray.Direction * 1000, params)
end

--// Create Preview
local function CreatePreview()
    if PreviewPart then PreviewPart:Destroy() end
    PreviewPart = Instance.new("Part")
    PreviewPart.Shape = CurrentShape == "Ball" and Enum.PartType.Ball or Enum.PartType.Block
    PreviewPart.Material = Enum.Material.ForceField
    PreviewPart.Color = Color3.fromRGB(255, 255, 255)
    PreviewPart.Transparency = 0.7
    PreviewPart.CanCollide = false
    PreviewPart.Anchored = true
    PreviewPart.CastShadow = false
    PreviewPart.Parent = Workspace
end

--// Update Preview
local function UpdatePreview()
    if not PreviewPart then CreatePreview() end
    local result = GetRaycast()
    if result then
        PreviewPos = result.Position
        if CurrentShape == "Ball" then
            PreviewPart.Shape = Enum.PartType.Ball
            PreviewPart.Size = Vector3.new(SizeX, SizeY, SizeZ)
        else
            PreviewPart.Shape = Enum.PartType.Block
            PreviewPart.Size = Vector3.new(SizeX, SizeY, SizeZ)
        end
        PreviewPart.Position = PreviewPos
        PreviewPart.Transparency = 0.65
    else
        PreviewPart.Transparency = 0.7
    end
end

