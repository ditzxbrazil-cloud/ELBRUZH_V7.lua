--// Deep Clone Function - NO HUMANOID, NO PLAYER CHARACTERS
local function DeepClone(instance, parent, onProgress, serviceName, stats)
    if shhhhnayy05.ShouldStop then return nil end
    
    --// SKIP: Humanoid, Player Characters, Scripts
    if instance:IsA("Humanoid") then 
        if stats then stats.skipped = stats.skipped + 1 end
        return nil 
    end
    if instance:IsA("Script") or instance:IsA("LocalScript") or instance:IsA("ModuleScript") then 
        if stats then stats.skipped = stats.skipped + 1 end
        return nil 
    end
    if IsPlayerCharacter(instance) then 
        if stats then stats.skipped = stats.skipped + 1 end
        return nil 
    end
    
    local clone
    local className = instance.ClassName
    
    --// Skip unwanted items
    if className == "Camera" or className == "Terrain" then 
        if stats then stats.skipped = stats.skipped + 1 end
        return nil 
    end
    
    --// Create instance based on class
    local success = pcall(function()
        if className == "Part" then
            clone = Instance.new("Part")
            clone.Size = instance.Size
            clone.CFrame = instance.CFrame
            clone.Color = instance.Color
            clone.Material = instance.Material
            clone.Transparency = instance.Transparency
            clone.Reflectance = instance.Reflectance
            clone.CanCollide = instance.CanCollide
            clone.Anchored = instance.Anchored
            clone.CastShadow = instance.CastShadow
            clone.Shape = instance.Shape
            for _, face in ipairs({"Top", "Bottom", "Left", "Right", "Front", "Back"}) do
                clone[face.."Surface"] = instance[face.."Surface"]
            end
            
        elseif className == "MeshPart" then
            clone = Instance.new("MeshPart")
            clone.Size = instance.Size
            clone.CFrame = instance.CFrame
            clone.Color = instance.Color
            clone.Material = instance.Material
            clone.Transparency = instance.Transparency
            clone.CanCollide = instance.CanCollide
            clone.Anchored = instance.Anchored
            clone.MeshId = instance.MeshId
            clone.TextureID = instance.TextureID
            
        elseif className == "WedgePart" then
            clone = Instance.new("WedgePart")
            clone.Size = instance.Size
            clone.CFrame = instance.CFrame
            clone.Color = instance.Color
            clone.Material = instance.Material
            clone.Transparency = instance.Transparency
