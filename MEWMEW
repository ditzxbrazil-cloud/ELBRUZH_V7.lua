    shhhhnayy05.ShouldStop = true
    shhhhnayy05.IsCopying = false
end

--// Load Map (Deserialize from saved data)
local function LoadMap(index)
    local map = shhhhnayy05.SavedMaps[index]
    if not map then return end
    
    Notify("📥 Loading: " .. map.Name .. "...", Color3.fromRGB(100, 150, 255))
    
    local function CreateFromData(data, parent)
        local inst
        local class = data.Class
        
        pcall(function()
            if class == "Part" then inst = Instance.new("Part")
            elseif class == "MeshPart" then inst = Instance.new("MeshPart")
            elseif class == "WedgePart" then inst = Instance.new("WedgePart")
            elseif class == "CornerWedgePart" then inst = Instance.new("CornerWedgePart")
            elseif class == "TrussPart" then inst = Instance.new("TrussPart")
            elseif class == "UnionOperation" then inst = Instance.new("UnionOperation")
            elseif class == "NegateOperation" then inst = Instance.new("NegateOperation")
            elseif class == "Model" then inst = Instance.new("Model")
            elseif class == "Folder" then inst = Instance.new("Folder")
            elseif class == "Decal" then inst = Instance.new("Decal")
            elseif class == "Texture" then inst = Instance.new("Texture")
            elseif class == "PointLight" then inst = Instance.new("PointLight")
            elseif class == "SpotLight" then inst = Instance.new("SpotLight")
            elseif class == "SurfaceLight" then inst = Instance.new("SurfaceLight")
            elseif class == "Sound" then inst = Instance.new("Sound")
            elseif class == "ParticleEmitter" then inst = Instance.new("ParticleEmitter")
            elseif class == "Fire" then inst = Instance.new("Fire")
            elseif class == "Smoke" then inst = Instance.new("Smoke")
            elseif class == "Sparkles" then inst = Instance.new("Sparkles")
            elseif class == "BillboardGui" then inst = Instance.new("BillboardGui")
            elseif class == "SurfaceGui" then inst = Instance.new("SurfaceGui")
            elseif class == "Frame" then inst = Instance.new("Frame")
            elseif class == "TextLabel" then inst = Instance.new("TextLabel")
            elseif class == "TextButton" then inst = Instance.new("TextButton")
            elseif class == "ImageLabel" then inst = Instance.new("ImageLabel")
            elseif class == "ImageButton" then inst = Instance.new("ImageButton")
            elseif class == "Weld" then inst = Instance.new("Weld")
            elseif class == "WeldConstraint" then inst = Instance.new("WeldConstraint")
            elseif class == "Motor" then inst = Instance.new("Motor")
            elseif class == "Motor6D" then inst = Instance.new("Motor6D")
            elseif class == "Attachment" then inst = Instance.new("Attachment")
            elseif class == "Humanoid" then inst = Instance.new("Humanoid")
            elseif class == "Accessory" then inst = Instance.new("Accessory")
            elseif class == "Tool" then inst = Instance.new("Tool")
            elseif class == "Seat" then inst = Instance.new("Seat")
            elseif class == "VehicleSeat" then inst = Instance.new("VehicleSeat")
            elseif class == "SpawnLocation" then inst = Instance.new("SpawnLocation")
            elseif class == "ClickDetector" then inst = Instance.new("ClickDetector")
            elseif class == "ProximityPrompt" then inst = Instance.new("ProximityPrompt")
            elseif class == "Sky" then inst = Instance.new("Sky")
            elseif class == "Atmosphere" then inst = Instance.new("Atmosphere")
            elseif class == "BloomEffect" then inst = Instance.new("BloomEffect")
            elseif class == "BlurEffect" then inst = Instance.new("BlurEffect")
            elseif class == "ColorCorrectionEffect" then inst = Instance.new("ColorCorrectionEffect")
            elseif class == "DepthOfFieldEffect" then inst = Instance.new("DepthOfFieldEffect")
            elseif class == "SunRaysEffect" then inst = Instance.new("SunRaysEffect")
            elseif class == "Team" then inst = Instance.new("Team")
            elseif class == "ScreenGui" then inst = Instance.new("ScreenGui")
            elseif class == "ScrollingFrame" then inst = Instance.new("ScrollingFrame")
            elseif class == "TextBox" then inst = Instance.new("TextBox")
            elseif class == "ViewportFrame" then inst = Instance.new("ViewportFrame")
            elseif class == "UIListLayout" then inst = Instance.new("UIListLayout")
            elseif class == "UIGridLayout" then inst = Instance.new("UIGridLayout")
            elseif class == "UICorner" then inst = Instance.new("UICorner")
            elseif class == "UIStroke" then inst = Instance.new("UIStroke")
            elseif class == "UIGradient" then inst = Instance.new("UIGradient")
            elseif class == "UIPadding" then inst = Instance.new("UIPadding")
            elseif class == "UIScale" then inst = Instance.new("UIScale")
            else inst = Instance.new("Folder") end
            
            inst.Name = data.Name
            
            if data.Props then
                for prop, val in pairs(data.Props) do
                    pcall(function()
                        if prop == "CFrame" and typeof(val) == "table" then
                            inst.CFrame = CFrame.new(unpack(val))
                        elseif prop == "Size" and typeof(val) == "table" then
                            inst.Size = Vector3.new(unpack(val))
                        elseif prop == "Color" and typeof(val) == "table" then
                            inst.Color = Color3.new(unpack(val))
                        elseif prop == "Material" then
                            inst.Material = Enum.Material[val]
                        elseif prop == "Shape" then
                            inst.Shape = Enum.PartType[val]
                        elseif prop == "Face" then
                            inst.Face = Enum.NormalId[val]
                        elseif prop == "Texture" then
                            inst.Texture = val
                        elseif prop == "MeshId" then
                            inst.MeshId = val
                        elseif prop == "TextureID" then
                            inst.TextureID = val
                        elseif prop == "SoundId" then
                            inst.SoundId = val
                        elseif prop == "Transparency" then
                            inst.Transparency = val
                        elseif prop == "CanCollide" then
                            inst.CanCollide = val
                        elseif prop == "Anchored" then
                            inst.Anchored = val
                        elseif prop == "Brightness" then
                            inst.Brightness = val
                        elseif prop == "Range" then
                            inst.Range = val
                        elseif prop == "Volume" then
                            inst.Volume = val
                        elseif prop == "SkyboxBk" then inst.SkyboxBk = val
                        elseif prop == "SkyboxDn" then inst.SkyboxDn = val
                        elseif prop == "SkyboxFt" then inst.SkyboxFt = val
                        elseif prop == "SkyboxLf" then inst.SkyboxLf = val
                        elseif prop == "SkyboxRt" then inst.SkyboxRt = val
                        elseif prop == "SkyboxUp" then inst.SkyboxUp = val
                        end
                    end)
                end
            end
            
            inst.Parent = parent
            
            for _, childData in ipairs(data.Children) do
                CreateFromData(childData, inst)
            end
        end)
        
        return inst
    end
    
    local folder = Instance.new("Folder")
    folder.Name = "shhhhnayy05_Loaded_" .. map.Name
    folder.Parent = Workspace
    
    local count = 0
    for _, objData in ipairs(map.Data.Objects) do
        CreateFromData(objData, folder)
        count = count + 1
        if count % 20 == 0 then
            RunService.Heartbeat:Wait()
        end
    end
    
    pcall(function()
        if game.Selection then
            game.Selection:Set({folder})
        end
    end)
    
    Notify(string.format("✅ Loaded: %d objects", count), Color3.fromRGB(100, 255, 150))
end

