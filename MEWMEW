--// Executor Detection
local function GetExecutor()
    if syn then return "Synapse X"
    elseif KRNL_LOADED then return "Krnl"
    elseif identifyexecutor then return identifyexecutor()
    elseif getexecutorname then return getexecutorname()
    elseif fluxus then return "Fluxus"
    elseif codex then return "Codex"
    elseif delta then return "Delta"
    elseif hydrogen then return "Hydrogen"
    elseif oxygen then return "Oxygen U"
    elseif electron then return "Electron"
    elseif is_sirhurt_closure then return "SirHurt"
    elseif pebc_execute then return "Panda"
    else return "Unknown" end
end

