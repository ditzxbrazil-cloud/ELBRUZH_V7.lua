--// FIXED: Start Copy Process with complete service iteration
local function StartCopy()
    if shhhhnayy05.IsCopying then return end
    
    local mapName = NameInput.Text
    if mapName == "" then
        mapName = "Map_" .. game.PlaceId .. "_" .. os.time()
    end
    mapName = mapName:gsub("[^%w%s_-]", ""):gsub("%s+", "_")
    
    shhhhnayy05.IsCopying = true
    shhhhnayy05.ShouldStop = false
    CopyBtn.Visible = false
    StopBtn.Visible = true
    
    -- Reset progress
    ProgressBar.Size = UDim2.new(0, 0, 1, 0)
    ProgressBar.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
    ProgressText.Text = "0% - Initializing..."
    DetailText.Text = "Starting..."
    DetailText.TextColor3 = Color3.fromRGB(255, 200, 100)
    
    local servicesToCopy = GetServicesToCopy()
    
    if #servicesToCopy == 0 then
        Notify("⚠️ No services selected!", Color3.fromRGB(255, 100, 100))
        shhhhnayy05.IsCopying = false
        CopyBtn.Visible = true
        StopBtn.Visible = false
        DetailText.Text = "❌ Select at least one service"
        return
    end
    
    -- PHASE 1: Count total objects accurately
    DetailText.Text = "🔍 Analyzing " .. #servicesToCopy .. " services..."
    
    local totalObjects = 0
    local serviceObjects = {}
    
    for svcIndex, svcInfo in ipairs(servicesToCopy) do
        local svc = svcInfo.Service
        local svcName = svcInfo.Name
        local svcCount = 0
        local svcItems = {}
        
        -- Count all valid items in this service
        for _, item in ipairs(svc:GetChildren()) do
            -- Skip unwanted
            if item:IsA("Terrain") or item:IsA("Camera") then continue end
            if item:IsA("Humanoid") then continue end
            if IsPlayerCharacter(item) then continue end
            
            -- Count this item and all descendants
            local itemCount = 1
            for _, desc in ipairs(item:GetDescendants()) do
                if not desc:IsA("Humanoid") and not IsPlayerCharacter(desc) then
                    itemCount = itemCount + 1
                end
            end
            
            table.insert(svcItems, {Item = item, Count = itemCount})
            svcCount = svcCount + itemCount
            
            -- Yield to prevent freeze
            if svcCount % 1000 == 0 then
                RunService.Heartbeat:Wait()
            end
        end
        
        serviceObjects[svcName] = {
            Items = svcItems,
            Count = svcCount,
            Service = svc,
            Index = svcIndex
        }
        totalObjects = totalObjects + svcCount
        
        -- Update counting progress
        local countProgress = math.min(10, math.floor((svcIndex / #servicesToCopy) * 10))
        ProgressBar.Size = UDim2.new(countProgress / 100, 0, 1, 0)
        ProgressText.Text = countProgress .. "% - Counting " .. svcName .. " (" .. svcCount .. " objects)..."
    end
    
    ProgressBar.Size = UDim2.new(0.1, 0, 1, 0)
    ProgressBar.BackgroundColor3 = Color3.fromRGB(255, 200, 80)
    ProgressText.Text = "10% - Found " .. totalObjects .. " objects in " .. #servicesToCopy .. " services"
    
    if totalObjects == 0 then
        Notify("⚠️ No objects found to copy!", Color3.fromRGB(255, 100, 100))
        shhhhnayy05.IsCopying = false
        CopyBtn.Visible = true
        StopBtn.Visible = false
        DetailText.Text = "❌ No objects found"
        return
    end
    
    -- PHASE 2: Copy all services
    local mainContainer = Instance.new("Folder")
    mainContainer.Name = "shhhhnayy05_Copy_" .. mapName
    mainContainer.Parent = Workspace
    
    local stats = {
        copied = 0,
        skipped = 0,
        failed = 0,
        currentService = ""
    }
    
    local startTime = tick()
    local lastUpdate = 0
    local objectsProcessed = 0
    
    local copyProgressRange = 80 -- 10% to 90%
    local progressPerObject = copyProgressRange / totalObjects
    
    -- FIXED: Iterate through ALL services properly
    for svcIndex, svcInfo in ipairs(servicesToCopy) do
        if shhhhnayy05.ShouldStop then break end
        
        local svcName = svcInfo.Name
        local svcData = serviceObjects[svcName]
        
        if not svcData or svcData.Count == 0 then
            -- Skip empty services but continue to next
            continue
        end
        
        stats.currentService = svcName
        
        -- Create service folder
        local svcFolder = Instance.new("Folder")
        svcFolder.Name = svcName
        svcFolder.Parent = mainContainer
        
        DetailText.Text = "📦 [" .. svcIndex .. "/" .. #servicesToCopy .. "] " .. svcName .. " (" .. #svcData.Items .. " items, " .. svcData.Count .. " objects)"
        DetailText.TextColor3 = Color3.fromRGB(100, 200, 255)
        
        -- Copy each item in this service
        for itemIndex, itemData in ipairs(svcData.Items) do
            if shhhhnayy05.ShouldStop then break end
            
            local item = itemData.Item
            
            -- Clone with progress tracking
            DeepClone(item, svcFolder, function(childName, sName, childStats)
                objectsProcessed = objectsProcessed + 1
                
                -- Calculate accurate progress
                local currentProgress = 10 + (objectsProcessed * progressPerObject)
                currentProgress = math.clamp(currentProgress, 10, 90)
                
                -- Update UI (throttled)
                local now = tick()
                if objectsProcessed % 5 == 0 or (now - lastUpdate) > 0.1 then
                    lastUpdate = now
                    
                    -- Color coding
                    if currentProgress < 40 then
                        ProgressBar.BackgroundColor3 = Color3.fromRGB(255, 100, 100)
                    elseif currentProgress < 70 then
                        ProgressBar.BackgroundColor3 = Color3.fromRGB(255, 200, 80)
                    else
                        ProgressBar.BackgroundColor3 = Color3.fromRGB(100, 255, 100)
                    end
                    
                    ProgressBar.Size = UDim2.new(currentProgress / 100, 0, 1, 0)
                    ProgressText.Text = string.format("%d%% - %s > %s (%d/%d)", 
                        math.floor(currentProgress), svcName, childName, objectsProcessed, totalObjects)
                    
                    RunService.Heartbeat:Wait()
                end
            end, svcName, stats)
        end
        
        -- Service completed notification
        DetailText.Text = "✅ [" .. svcIndex .. "/" .. #servicesToCopy .. "] " .. svcName .. " completed"
        task.wait(0.1) -- Brief pause between services
    end
    
    -- PHASE 3: Save to file (90% - 100%)
    if not shhhhnayy05.ShouldStop then
        DetailText.Text = "💾 Saving to file..."
        ProgressBar.Size = UDim2.new(0.9, 0, 1, 0)
        ProgressText.Text = "90% - Serializing..."
        ProgressBar.BackgroundColor3 = Color3.fromRGB(100, 255, 150)
        
        -- Serialize with complete data
        local function SerializeToTable(inst)
            local data = {
                Class = inst.ClassName,
                Name = inst.Name,
                Props = {},
                Children = {}
            }
            
            local success, err = pcall(function()
                -- BasePart properties - INCLUDING ANCHORED
                if inst:IsA("BasePart") then
                    data.Props.CFrame = {inst.CFrame:GetComponents()}
                    data.Props.Size = {inst.Size.X, inst.Size.Y, inst.Size.Z}
                    data.Props.Position = {inst.Position.X, inst.Position.Y, inst.Position.Z}
                    data.Props.Orientation = {inst.Orientation.X, inst.Orientation.Y, inst.Orientation.Z}
                    data.Props.Color = {inst.Color.R, inst.Color.G, inst.Color.B}
                    data.Props.Material = tostring(inst.Material)
                    data.Props.Transparency = inst.Transparency
                    data.Props.Reflectance = inst.Reflectance
                    -- CRITICAL: Anchored property
                    data.Props.Anchored = inst.Anchored
                    data.Props.CanCollide = inst.CanCollide
                    data.Props.CanTouch = inst.CanTouch
                    data.Props.CanQuery = inst.CanQuery
                    data.Props.CastShadow = inst.CastShadow
                    
                    if inst:IsA("Part") then
                        data.Props.Shape = tostring(inst.Shape)
                    elseif inst:IsA("TrussPart") then
                        data.Props.Style = tostring(inst.Style)
                    end
                end
                
                -- MeshPart specific
                if inst:IsA("MeshPart") then
                    data.Props.MeshId = inst.MeshId
                    data.Props.TextureID = inst.TextureID
                    data.Props.CollisionFidelity = tostring(inst.CollisionFidelity)
                    data.Props.RenderFidelity = tostring(inst.RenderFidelity)
                end
                
                -- Decal/Texture
                if inst:IsA("Decal") or inst:IsA("Texture") then
                    data.Props.Texture = inst.Texture
                    data.Props.Face = tostring(inst.Face)
                    data.Props.Transparency = inst.Transparency
                    data.Props.Color3 = {inst.Color3.R, inst.Color3.G, inst.Color3.B}
                end
                
                -- Light
                if inst:IsA("Light") then
                    data.Props.Color = {inst.Color.R, inst.Color.G, inst.Color.B}
                    data.Props.Brightness = inst.Brightness
                    data.Props.Range = inst.Range
                    data.Props.Shadows = inst.Shadows
                    data.Props.Enabled = inst.Enabled
                end
                
                -- Sound
                if inst:IsA("Sound") then
                    data.Props.SoundId = inst.SoundId
                    data.Props.Volume = inst.Volume
                    data.Props.PlaybackSpeed = inst.PlaybackSpeed
                    data.Props.Looped = inst.Looped
                    data.Props.RollOffMode = tostring(inst.RollOffMode)
                end
                
                -- ParticleEmitter
                if inst:IsA("ParticleEmitter") then
                    data.Props.Texture = inst.Texture
                    data.Props.Rate = inst.Rate
                    data.Props.Speed = {inst.Speed.Min, inst.Speed.Max}
                    data.Props.Lifetime = {inst.Lifetime.Min, inst.Lifetime.Max}
                    data.Props.Enabled = inst.Enabled
                end
                
                -- GUI Objects
                if inst:IsA("GuiObject") then
                    data.Props.Size = {
                        ScaleX = inst.Size.X.Scale,
                        OffsetX = inst.Size.X.Offset,
                        ScaleY = inst.Size.Y.Scale,
                        OffsetY = inst.Size.Y.Offset
                    }
                    data.Props.Position = {
                        ScaleX = inst.Position.X.Scale,
                        OffsetX = inst.Position.X.Offset,
                        ScaleY = inst.Position.Y.Scale,
                        OffsetY = inst.Position.Y.Offset
                    }
                    data.Props.BackgroundColor3 = {inst.BackgroundColor3.R, inst.BackgroundColor3.G, inst.BackgroundColor3.B}
                    data.Props.BackgroundTransparency = inst.BackgroundTransparency
                    data.Props.BorderSizePixel = inst.BorderSizePixel
                    data.Props.ZIndex = inst.ZIndex
                    data.Props.Visible = inst.Visible
                end
                
                -- Text objects
                if inst:IsA("TextLabel") or inst:IsA("TextButton") or inst:IsA("TextBox") then
                    data.Props.Text = inst.Text
                    data.Props.TextColor3 = {inst.TextColor3.R, inst.TextColor3.G, inst.TextColor3.B}
                    data.Props.TextScaled = inst.TextScaled
                    data.Props.TextSize = inst.TextSize
                    data.Props.Font = tostring(inst.Font)
                    data.Props.TextXAlignment = tostring(inst.TextXAlignment)
                    data.Props.TextYAlignment = tostring(inst.TextYAlignment)
                end
                
                -- Constraints
                if inst:IsA("Weld") or inst:IsA("Motor") or inst:IsA("Motor6D") or inst:IsA("Snap") then
                    if inst.C0 then
                        data.Props.C0 = {inst.C0:GetComponents()}
                    end
                    if inst.C1 then
                        data.Props.C1 = {inst.C1:GetComponents()}
                    end
                    if inst:IsA("Motor") then
                        data.Props.DesiredAngle = inst.DesiredAngle
                        data.Props.MaxVelocity = inst.MaxVelocity
                    end
                end
                
                -- Sky
                if inst:IsA("Sky") then
                    data.Props.SkyboxBk = inst.SkyboxBk
                    data.Props.SkyboxDn = inst.SkyboxDn
                    data.Props.SkyboxFt = inst.SkyboxFt
                    data.Props.SkyboxLf = inst.SkyboxLf
                    data.Props.SkyboxRt = inst.SkyboxRt
                    data.Props.SkyboxUp = inst.SkyboxUp
                end
                
                -- Atmosphere
                if inst:IsA("Atmosphere") then
                    data.Props.Density = inst.Density
                    data.Props.Color = {inst.Color.R, inst.Color.G, inst.Color.B}
                    data.Props.Decay = {inst.Decay.R, inst.Decay.G, inst.Decay.B}
                end
                
                -- Post-processing effects
                if inst:IsA("BloomEffect") or inst:IsA("BlurEffect") or inst:IsA("ColorCorrectionEffect") or 
                   inst:IsA("DepthOfFieldEffect") or inst:IsA("SunRaysEffect") then
                    data.Props.Enabled = inst.Enabled
                    if inst:IsA("BloomEffect") then
                        data.Props.Intensity = inst.Intensity
                        data.Props.Size = inst.Size
                    elseif inst:IsA("BlurEffect") then
                        data.Props.Size = inst.Size
                    elseif inst:IsA("ColorCorrectionEffect") then
                        data.Props.Brightness = inst.Brightness
                        data.Props.Contrast = inst.Contrast
                        data.Props.Saturation = inst.Saturation
                    end
                end
                
                -- UI Layouts
                if inst:IsA("UIListLayout") then
                    data.Props.Padding = {
                        Scale = inst.Padding.Scale,
                        Offset = inst.Padding.Offset
                    }
                    data.Props.SortOrder = tostring(inst.SortOrder)
                    data.Props.FillDirection = tostring(inst.FillDirection)
                end
                
                -- UICorner
                if inst:IsA("UICorner") then
                    data.Props.CornerRadius = {
                        Scale = inst.CornerRadius.Scale,
                        Offset = inst.CornerRadius.Offset
                    }
                end
                
                -- UIStroke
                if inst:IsA("UIStroke") then
                    data.Props.Color = {inst.Color.R, inst.Color.G, inst.Color.B}
                    data.Props.Thickness = inst.Thickness
                    data.Props.Transparency = inst.Transparency
                end
            end)
            
            if not success then
                warn("Serialize error for " .. inst.Name .. ": " .. tostring(err))
            end
            
            -- Serialize children recursively
            for _, child in ipairs(inst:GetChildren()) do
                table.insert(data.Children, SerializeToTable(child))
            end
            
            return data
        end
        
        local mapData = {
            Meta = {
                Name = mapName,
                PlaceId = game.PlaceId,
                PlaceName = game:GetService("MarketplaceService"):GetProductInfo(game.PlaceId).Name,
                Created = os.date("%Y-%m-%d %H:%M:%S"),
                TotalObjects = stats.copied,
                Skipped = stats.skipped,
                Failed = stats.failed,
                Executor = GetExecutor(),
                Services = {}
            },
            Objects = {}
        }
        
        -- Collect all service data
        for _, svcFolder in ipairs(mainContainer:GetChildren()) do
            table.insert(mapData.Meta.Services, svcFolder.Name)
            for _, child in ipairs(svcFolder:GetChildren()) do
                table.insert(mapData.Objects, SerializeToTable(child))
            end
        end
        
        ProgressBar.Size = UDim2.new(0.95, 0, 1, 0)
        ProgressText.Text = "95% - Writing file..."
        
        -- Save to file
        local fileSaved = false
        local jsonData = ""
        
        local encodeSuccess, encodeErr = pcall(function()
            jsonData = HttpService:JSONEncode(mapData)
        end)
        
        if encodeSuccess and jsonData and jsonData ~= "" then
            local fileName = shhhhnayy05.MapsFolder .. "/" .. mapName .. ".json"
            
            local writeSuccess, writeErr = pcall(function()
                if writefile then
                    writefile(fileName, jsonData)
                    if isfile and isfile(fileName) then
                        fileSaved = true
                    end
                end
            end)
            
            if not writeSuccess then
                warn("Failed to write file: " .. tostring(writeErr))
            end
            
            -- Store in memory
            table.insert(shhhhnayy05.SavedMaps, {
                Name = mapName,
                Data = mapData,
                Container = mainContainer,
                File = fileSaved and fileName or nil,
                Size = #jsonData,
                SavedAt = os.time()
            })
            
            mainContainer.Name = "shhhhnayy05_Saved_" .. mapName
            
            ProgressBar.Size = UDim2.new(1, 0, 1, 0)
            ProgressBar.BackgroundColor3 = Color3.fromRGB(0, 255, 100)
            ProgressText.Text = "100% - Complete!"
            
            if fileSaved then
                Notify(string.format("✅ Saved: %s (%d objects)", mapName, stats.copied), Color3.fromRGB(100, 255, 150))
            else
                Notify(string.format("⚠️ Memory only: %s", mapName), Color3.fromRGB(255, 200, 100))
            end
            
            RefreshList()
        else
            warn("Failed to encode JSON: " .. tostring(encodeErr))
            Notify("❌ Failed to save map!", Color3.fromRGB(255, 100, 100))
            mainContainer:Destroy()
        end
    else
        mainContainer:Destroy()
        Notify("⏹️ Copy cancelled", Color3.fromRGB(255, 150, 100))
    end
    
    -- Reset UI
    shhhhnayy05.IsCopying = false
    CopyBtn.Visible = true
    StopBtn.Visible = false
    
    if not shhhhnayy05.ShouldStop then
        DetailText.Text = string.format("✅ Done in %.1fs | Copied: %d | Skipped: %d | Failed: %d", 
            tick() - startTime, stats.copied, stats.skipped, stats.failed)
        DetailText.TextColor3 = Color3.fromRGB(100, 255, 150)
        
        task.delay(3, function()
            ProgressBar.Size = UDim2.new(0, 0, 1, 0)
            ProgressBar.BackgroundColor3 = Color3.fromRGB(0, 200, 100)
            ProgressText.Text = "0% - Ready"
            DetailText.Text = "Waiting..."
            DetailText.TextColor3 = Color3.fromRGB(180, 180, 180)
        end)
    else
        ProgressBar.Size = UDim2.new(0, 0, 1, 0)
        ProgressBar.BackgroundColor3 = Color3.fromRGB(0, 200, 100)
        ProgressText.Text = "0% - Ready"
        DetailText.Text = "Waiting..."
        DetailText.TextColor3 = Color3.fromRGB(180, 180, 180)
    end
end

--// Stop Copy
