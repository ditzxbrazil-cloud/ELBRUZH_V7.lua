    end
    
    -- Set name and parent
    clone.Name = instance.Name
    clone.Parent = parent
    
    if stats then stats.copied = stats.copied + 1 end
    
    -- Progress callback
    if onProgress then
        onProgress(instance.Name, serviceName, stats)
    end
    
    --// Clone children recursively
    for _, child in ipairs(instance:GetChildren()) do
        DeepClone(child, clone, onProgress, serviceName, stats)
        if shhhhnayy05.ShouldStop then return nil end
    end
    
    --// FIXED: Set PrimaryPart for Model after children cloned
    if className == "Model" and instance.PrimaryPart then
