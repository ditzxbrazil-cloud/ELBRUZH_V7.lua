                            inst.Shape = Enum.PartType[val]
                        -- Style (TrussPart)
                        elseif prop == "Style" and typeof(val) == "string" then
                            inst.Style = Enum.Style[val]
                        -- Face
                        elseif prop == "Face" and typeof(val) == "string" then
                            inst.Face = Enum.NormalId[val]
                        -- Texture
                        elseif prop == "Texture" then
                            inst.Texture = val
                        -- MeshId
                        elseif prop == "MeshId" then
                            inst.MeshId = val
                        -- TextureID
                        elseif prop == "TextureID" then
                            inst.TextureID = val
                        -- SoundId
                        elseif prop == "SoundId" then
