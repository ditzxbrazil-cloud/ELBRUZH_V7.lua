                            inst.ZIndex = val
                        -- Visible
                        elseif prop == "Visible" then
                            inst.Visible = val
                        -- BackgroundTransparency
                        elseif prop == "BackgroundTransparency" then
                            inst.BackgroundTransparency = val
                        -- BorderSizePixel
                        elseif prop == "BorderSizePixel" then
                            inst.BorderSizePixel = val
                        -- Size (UDim2)
                        elseif prop == "Size" and typeof(val) == "table" and val.ScaleX then
                            inst.Size = UDim2.new(val.ScaleX, val.OffsetX, val.ScaleY, val.OffsetY)
                        -- Position (UDim2)
                        elseif prop == "Position" and typeof(val) == "table" and val.ScaleX then
                            inst.Position = UDim2.new(val.ScaleX, val.OffsetX, val.ScaleY, val.OffsetY)
                        -- Font
                        elseif prop == "Font" and typeof(val) == "string" then
                            inst.Font = Enum.Font[val]
                        -- TextXAlignment
                        elseif prop == "TextXAlignment" and typeof(val) == "string" then
                            inst.TextXAlignment = Enum.TextXAlignment[val]
                        -- TextYAlignment
                        elseif prop == "TextYAlignment" and typeof(val) == "string" then
                            inst.TextYAlignment = Enum.TextYAlignment[val]
                        -- C0 (Weld/Motor)
                        elseif prop == "C0" and typeof(val) == "table" then
                            inst.C0 = CFrame.new(unpack(val))
                        -- C1 (Weld/Motor)
                        elseif prop == "C1" and typeof(val) == "table" then
                            inst.C1 = CFrame.new(unpack(val))
                        -- DesiredAngle
                        elseif prop == "DesiredAngle" then
                            inst.DesiredAngle = val
                        -- MaxVelocity
                        elseif prop == "MaxVelocity" then
                            inst.MaxVelocity = val
                        -- CornerRadius
                        elseif prop == "CornerRadius" and typeof(val) == "table" then
                            inst.CornerRadius = UDim.new(val.Scale, val.Offset)
                        -- Padding
                        elseif prop == "Padding" and typeof(val) == "table" then
                            inst.Padding = UDim.new(val.Scale, val.Offset)
                        end
                    end)
                end
            end
            
            -- Set parent
            inst.Parent = parent
            
            -- Create children recursively
            if data.Children then
                for _, childData in ipairs(data.Children) do
                    CreateFromData(childData, inst)
                end
            end
            
            -- Set PrimaryPart for Model after children created
            if class == "Model" and data.Props and data.Props.PrimaryPart then
                pcall(function()
                    inst.PrimaryPart = inst:FindFirstChild(data.Props.PrimaryPart)
                end)
            end
        end)
        
        if not success then
            warn("Failed to create " .. class .. ": " .. tostring(err))
        end
        
        return inst
    end
    
    -- Create main folder
    local folder = Instance.new("Folder")
    folder.Name = "shhhhnayy05_Loaded_" .. map.Name
    folder.Parent = Workspace
    
    -- Create all objects
    local count = 0
    for _, objData in ipairs(map.Data.Objects) do
        CreateFromData(objData, folder)
        count = count + 1
        if count % 20 == 0 then
            RunService.Heartbeat:Wait()
        end
    end
    
    -- Select in explorer
    pcall(function()
        if game.Selection then
            game.Selection:Set({folder})
        end
    end)
    
    Notify(string.format("✅ Loaded: %d objects", count), Color3.fromRGB(100, 255, 150))
end

